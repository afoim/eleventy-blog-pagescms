---
layout: layouts/base.njk
eleventyNavigation:
  key: 鎼滅储
  order: 4
permalink: /search/
---

<style>
.search-box {
	width: 100%;
	padding: 0.6em 0.8em;
	font-size: 1.1em;
	border: 1px solid #2a3a4e;
	border-radius: 6px;
	background: #1a2a3d;
	color: #dad8d8;
	outline: none;
	margin-bottom: 1.5em;
}
.search-box:focus {
	border-color: #4d96ff;
}
.search-info {
	font-size: 0.85em;
	color: #888;
	margin-bottom: 1em;
}
.search-result {
	display: flex;
	gap: 1em;
	align-items: flex-start;
	padding: 0.8em 0;
	border-bottom: 1px solid #2a3a4e;
}
.search-result:last-child {
	border-bottom: none;
}
.search-result-cover {
	width: 80px;
	height: 60px;
	object-fit: cover;
	border-radius: 4px;
	flex-shrink: 0;
}
.search-result-body {
	flex: 1;
	min-width: 0;
}
.search-result-title {
	font-size: 1.1em;
	font-weight: 700;
	margin-bottom: 0.2em;
}
.search-result-title a {
	color: var(--text-color-link);
	text-decoration: none;
}
.search-result-title a:hover {
	text-decoration: underline;
}
.search-result-desc {
	font-size: 0.9em;
	color: var(--color-gray-90);
	line-height: 1.4;
	margin-bottom: 0.2em;
}
.search-result-matches {
	font-size: 0.82em;
	color: #ffd700;
	font-weight: 700;
}
.search-empty {
	color: #888;
	text-align: center;
	padding: 2em;
}
</style>

<h1>鎼滅储</h1>

<input type="search" class="search-box" id="searchInput" placeholder="杈撳叆鍏抽敭璇嶆悳绱⑩€? autofocus>
<p class="search-info" id="searchInfo"></p>
<div id="searchResults"></div>

{%- js %}
const searchInput = document.getElementById('searchInput');
const searchResults = document.getElementById('searchResults');
const searchInfo = document.getElementById('searchInfo');

function stripHTML(html) {
	const d = document.createElement('div');
	d.innerHTML = html;
	return d.textContent || d.innerText || '';
}

let feedData = [];

async function loadFeed() {
	try {
		const res = await fetch('/feed/feed.xml');
		const xml = await res.text();
		const parser = new DOMParser();
		const doc = parser.parseFromString(xml, 'text/xml');
		const entries = doc.querySelectorAll('entry');
		feedData = [];
		entries.forEach(entry => {
			const title = entry.querySelector('title')?.textContent || '';
			const link = (() => { try { return new URL(entry.querySelector('link')?.getAttribute('href') || '', location.origin).pathname; } catch(e) { return ''; } })();
			const desc = entry.querySelector('description')?.textContent || '';
			const coverEl = entry.querySelector('coverimage');
			const cover = coverEl?.textContent || '';
			const content = stripHTML(entry.querySelector('content')?.textContent || '');
			feedData.push({ title, link, desc, cover, content });
		});
		searchInfo.textContent = `宸茬储寮?${feedData.length} 绡囨枃绔燻;
	} catch (e) {
		searchInfo.textContent = '鏃犳硶鍔犺浇鎼滅储绱㈠紩';
	}
}

function countMatches(text, terms) {
	let count = 0;
	for (const term of terms) {
		const re = new RegExp(term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'gi');
		const matches = text.match(re);
		if (matches) count += matches.length;
	}
	return count;
}

function doSearch() {
	const query = searchInput.value.trim();
	if (!query) {
		searchResults.innerHTML = '';
		searchInfo.textContent = `宸茬储寮?${feedData.length} 绡囨枃绔燻;
		return;
	}

	const terms = query.split(/\s+/).filter(Boolean);
	const results = feedData
		.map(item => {
			const titleMatches = countMatches(item.title, terms);
			const descMatches = countMatches(item.desc, terms);
			const contentMatches = countMatches(item.content, terms);
			const total = titleMatches + descMatches + contentMatches;
			return { ...item, total, titleMatches, descMatches, contentMatches };
		})
		.filter(item => item.total > 0)
		.sort((a, b) => b.total - a.total);

	if (results.length === 0) {
		searchResults.innerHTML = '<p class="search-empty">娌℃湁鎵惧埌鍖归厤鐨勭粨鏋?/p>';
		searchInfo.textContent = `鍏?0 鏉＄粨鏋滐紙宸茬储寮?${feedData.length} 绡囷級`;
		return;
	}

	searchResults.innerHTML = results.map(item => `
		<div class="search-result">
			${item.cover ? `<img src="${item.cover}" alt="" class="search-result-cover" loading="lazy">` : ''}
			<div class="search-result-body">
				<div class="search-result-title"><a href="${item.link}">${item.title}</a></div>
				${item.desc ? `<div class="search-result-desc">${item.desc}</div>` : ''}
				<div class="search-result-matches">${item.total} 涓尮閰?/div>
			</div>
		</div>
	`).join('');

	searchInfo.textContent = `鍏?${results.length} 鏉＄粨鏋滐紙宸茬储寮?${feedData.length} 绡囷級`;
}

let debounceTimer;
searchInput.addEventListener('input', () => {
	clearTimeout(debounceTimer);
	debounceTimer = setTimeout(doSearch, 200);
});

loadFeed();
{% endjs %}
<script>{% getBundle "js" %}</script>

