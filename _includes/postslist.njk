<style>
.pin-gradient {
	display: inline-block;
	background-image: linear-gradient(90deg, #fff4d6, #d4af37, #996515);
	background-size: 200% 100%;
	background-position: 0% 50%;
	-webkit-background-clip: text;
	background-clip: text;
	-webkit-text-fill-color: transparent;
	animation: pinShine 3s linear infinite;
}
@keyframes pinShine {
	0% { background-position: 100% 50%; }
	100% { background-position: 0% 50%; }
}
</style>
<ol class="postlist">
{% for post in postslist | sortByPin %}
	<li class="postlist-item{% if post.url == url %} postlist-item-active{% endif %}">
		{%- if post.data.coverImage %}
		<a href="{{ post.url }}" class="postlist-cover-link">
			<img src="{{ post.data.coverImage }}" alt="" class="postlist-cover" loading="lazy">
		</a>
		{%- endif %}
		<div class="postlist-content">
			<a href="{{ post.url }}" class="postlist-link{% if post.data.pin %} postlist-link-pin{% endif %}">{% if post.data.pin %}<span class="pin-gradient">{% endif %}{% if post.data.title %}{{ post.data.title }}{% else %}<code>{{ post.url }}</code>{% endif %}{% if post.data.pin %}</span>{% endif %}</a>
			{%- if post.data.pin %}<span class="postlist-pin">📌 置顶</span>{%- endif %}
			{%- if post.data.description %}
			<p class="postlist-desc">{{ post.data.description }}</p>
			{%- endif %}
			<time class="postlist-date" datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
		</div>
	</li>
{% endfor %}
</ol>
